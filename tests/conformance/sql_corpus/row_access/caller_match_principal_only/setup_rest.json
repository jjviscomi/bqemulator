[
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}/tables/orders/rowAccessPolicies",
    "body": {
      "rowAccessPolicyReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}",
        "tableId": "orders",
        "policyId": "jp_for_principal_or_nobody"
      },
      "filterPredicate": "country = 'JP'",
      "grantees": ["${OTHER_PRINCIPAL}", "${PRINCIPAL}"]
    }
  }
]
