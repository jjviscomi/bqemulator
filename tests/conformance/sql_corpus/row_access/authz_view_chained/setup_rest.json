[
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets",
    "body": {
      "datasetReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}_views"
      },
      "location": "US"
    }
  },
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}_views/tables",
    "body": {
      "tableReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}_views",
        "tableId": "inner_view"
      },
      "view": {
        "query": "SELECT id, country FROM `${PROJECT}.${DATASET_ID}.orders`",
        "useLegacySql": false
      }
    }
  },
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}_views/tables",
    "body": {
      "tableReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}_views",
        "tableId": "outer_view"
      },
      "view": {
        "query": "SELECT id, country FROM `${PROJECT}.${DATASET_ID}_views.inner_view`",
        "useLegacySql": false
      }
    }
  },
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}/tables/orders/rowAccessPolicies",
    "body": {
      "rowAccessPolicyReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}",
        "tableId": "orders",
        "policyId": "blocks_principal_orders"
      },
      "filterPredicate": "country = 'US'",
      "grantees": ["${OTHER_PRINCIPAL}"]
    }
  },
  {
    "method": "PATCH",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}",
    "body": {
      "access": [
        {
          "view": {
            "projectId": "${PROJECT}",
            "datasetId": "${DATASET_ID}_views",
            "tableId": "inner_view"
          }
        },
        {
          "view": {
            "projectId": "${PROJECT}",
            "datasetId": "${DATASET_ID}_views",
            "tableId": "outer_view"
          }
        }
      ]
    }
  }
]
