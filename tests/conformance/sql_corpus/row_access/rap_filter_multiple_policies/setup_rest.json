[
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}/tables/orders/rowAccessPolicies",
    "body": {
      "rowAccessPolicyReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}",
        "tableId": "orders",
        "policyId": "us_only"
      },
      "filterPredicate": "country = 'US'",
      "grantees": ["${PRINCIPAL}"]
    }
  },
  {
    "method": "POST",
    "path": "/bigquery/v2/projects/${PROJECT}/datasets/${DATASET_ID}/tables/orders/rowAccessPolicies",
    "body": {
      "rowAccessPolicyReference": {
        "projectId": "${PROJECT}",
        "datasetId": "${DATASET_ID}",
        "tableId": "orders",
        "policyId": "big_amount"
      },
      "filterPredicate": "amount >= NUMERIC '300.00'",
      "grantees": ["${PRINCIPAL}"]
    }
  }
]
