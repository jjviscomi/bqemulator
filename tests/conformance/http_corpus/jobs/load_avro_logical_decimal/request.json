{
  "method": "POST",
  "path": "/bigquery/v2/projects/${PROJECT}/jobs",
  "body": {
    "configuration": {
      "load": {
        "destinationTable": {
          "projectId": "${PROJECT}",
          "datasetId": "${DATASET_ID}",
          "tableId": "amounts"
        },
        "sourceUris": ["gs://${GCS_BUCKET}/g1/load_avro_logical_decimal.avro"],
        "sourceFormat": "AVRO",
        "writeDisposition": "WRITE_TRUNCATE"
      }
    }
  }
}
